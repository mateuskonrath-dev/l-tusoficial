    "smooth": {
      "$value": "all 0.6s cubic-bezier(0.16, 1, 0.3, 1)",
      "$description": "Smooth transition",
      "$type": "transition"
    },
    "slow": {
      "$value": "all 1s cubic-bezier(0.16, 1, 0.3, 1)",
      "$description": "Slow transition",
      "$type": "transition"
    }
